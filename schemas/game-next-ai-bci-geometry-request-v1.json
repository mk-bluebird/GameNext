{
  "filename": "schemas/game-next-ai-bci-geometry-request-v1.json",
  "destination": "GameNext/schemas/game-next-ai-bci-geometry-request-v1.json",
  "contents": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "id": "game-next-ai-bci-geometry-request-v1",
    "title": "GameNext AI BCI Geometry Request - v1",
    "type": "object",
    "description": "Cross-environment BCI geometry request for GameNext, compatible with prior Rotting-Visuals contracts but not limited to horror.",
    "required": ["version", "experienceType", "regionHints", "bciSummary", "invariants"],
    "properties": {
      "version": {
        "type": "string",
        "const": "v1"
      },
      "experienceType": {
        "type": "string",
        "enum": [
          "monster-mode",
          "adventure-mode",
          "simulation-mode",
          "training-mode",
          "sandbox-mode"
        ]
      },
      "regionHints": {
        "type": "object",
        "required": ["style"],
        "properties": {
          "style": {
            "type": "string",
            "description": "Style pack identifier, e.g., Rotting-Visuals, Clean-Future, Urban-Grime, Fantasy-Glow."
          },
          "locale": {
            "type": "string",
            "description": "IETF BCP 47 locale code, e.g., en-US, ja-JP.",
            "pattern": "^[a-zA-Z]{2,3}(-[a-zA-Z0-9]{2,8})*$"
          },
          "platform": {
            "type": "string",
            "description": "Optional target platform hint, e.g., PC, Console, VR, AR."
          }
        },
        "additionalProperties": false
      },
      "bciSummary": {
        "type": "object",
        "required": [
          "stressScore",
          "stressBand",
          "attentionBand",
          "visualOverloadIndex",
          "startleSpike",
          "signalQuality"
        ],
        "properties": {
          "stressScore": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "stressBand": {
            "type": "string",
            "enum": ["low", "mid", "high"]
          },
          "attentionBand": {
            "type": "string",
            "enum": ["drifting", "focused", "locked"]
          },
          "visualOverloadIndex": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "startleSpike": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "signalQuality": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "additionalProperties": false
      },
      "invariants": {
        "type": "object",
        "required": ["CIC", "AOS", "DET", "LSG"],
        "properties": {
          "CIC": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "AOS": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "DET": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "LSG": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "UEC": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "EMD": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0"
          },
          "STCI": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "CDL": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "ARR": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "additionalProperties": false
      },
      "meta": {
        "type": "object",
        "description": "Optional client metadata, logging tags, or experiment identifiers.",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
}
